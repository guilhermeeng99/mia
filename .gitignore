# Rust / Tauri
/app/src-tauri/target/
/app/src-tauri/gen/

# Mobile icons (Windows-only v1 — tauri icon also emits android/ios sets we don't ship)
/app/src-tauri/icons/android/
/app/src-tauri/icons/ios/

# Fetched native binaries + downloaded models (acquired at build/runtime, never committed).
# Ignore the binaries' contents but keep the dir (.gitkeep) so bundle.resources has a parent.
/app/src-tauri/binaries/*
!/app/src-tauri/binaries/.gitkeep
/app/src-tauri/models/

# Node / Bun / Vite
node_modules/
/app/node_modules/
/app/dist/
.vite/
*.tsbuildinfo

# Bun
.bun/

# Environment
.env
.env.*

# Logs
*.log
npm-debug.log*
bun-debug.log*

# Editor / OS
.vscode/*
!.vscode/extensions.json
.idea/
Thumbs.db
.DS_Store
